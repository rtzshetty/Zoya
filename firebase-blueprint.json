{
  "entities": {
    "Chat": {
      "title": "Chat Message",
      "description": "A single message in a chat history.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "sender": { "type": "string", "enum": ["user", "zoya"] },
        "text": { "type": "string" },
        "timestamp": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "sender", "text", "timestamp"]
    }
  },
  "firestore": {
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of all chat messages."
    }
  }
}
